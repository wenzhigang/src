$primary: #1A3C34;
$gold: #C9A84C;
$bg: #F8F5F0;
$text-main: #1A1A1A;
$text-sub: #666666;
$white: #FFFFFF;

.home {
  background-color: $bg;
  min-height: 100vh;
}

// 顶部导航
.header {
  display: flex;
  align-items: center;
  padding: 16px 16px 12px;
  background-color: $white;
  gap: 12px;

  &-logo {
    font-size: 22px;
    font-weight: bold;
    color: $primary;
    flex-shrink: 0;
  }

  &-search {
    flex: 1;
    display: flex;
    align-items: center;
    background-color: #EEEEEE;
    border-radius: 20px;
    height: 36px;
    padding: 0 12px;
    gap: 6px;
  }
}

.search-icon {
  font-size: 14px;
}

.search-placeholder {
  font-size: 13px;
  color: #999999;
}

// 通用 Section
.section {
  margin-top: 20px;
  padding: 0 16px;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: $text-main;
}

.section-more {
  font-size: 13px;
  color: $primary;
}

// 今日推荐大图 - 加高并显示顶部
.featured-card {
  position: relative;
  width: 100%;
  height: 320px;
  border-radius: 12px;
  overflow: hidden;
  background-color: #1a1a1a;
}

.featured-image {
  width: 100%;
  height: 100%;
}

.featured-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  background: linear-gradient(transparent, rgba(0,0,0,0.75));
}

.featured-title {
  display: block;
  font-size: 20px;
  font-weight: bold;
  color: $white;
}

.featured-artist {
  display: block;
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  margin-top: 4px;
}

// 热门艺术家横向滚动
.artist-scroll {
  white-space: nowrap;
  margin: 0 -16px;
  padding: 0 16px;
}

.artist-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16px;
  width: 70px;
}

.artist-avatar {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  background-color: #ddd;
}

.artist-name {
  font-size: 12px;
  color: $text-main;
  margin-top: 6px;
  text-align: center;
}

// 博物馆横向滚动
.museum-scroll {
  white-space: nowrap;
  margin: 0 -16px;
  padding: 0 16px;
}

.museum-card {
  display: inline-block;
  position: relative;
  width: 200px;
  height: 110px;
  border-radius: 12px;
  overflow: hidden;
  margin-right: 12px;
}

.museum-image {
  width: 100%;
  height: 100%;
}

.museum-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8px 10px;
  background: linear-gradient(transparent, rgba(0,0,0,0.65));
}

.museum-name {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: $white;
}

.museum-city {
  display: block;
  font-size: 11px;
  color: rgba(255,255,255,0.8);
}

// 最新收录双列网格
.artwork-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin: 0 -5px;
}

.artwork-card {
  width: 50%;
  padding: 0 5px;
  box-sizing: border-box;
  border-radius: 8px;
  overflow: hidden;
  background-color: $white;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.artwork-image {
  width: 100%;
  height: 140px;
}

.artwork-info {
  padding: 8px 10px 10px;
}

.artwork-title {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: $text-main;
}

.artwork-artist {
  display: block;
  font-size: 11px;
  color: $text-sub;
  margin-top: 3px;
}

// 底部留白
.bottom-space {
  height: 60px;
}

// 加载状态
.loading-container {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: $bg;
}

.loading-text {
  font-size: 15px;
  color: $text-sub;
}
